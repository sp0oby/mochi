# Mochi Garden frontend env — copy to .env.local and fill in.
# .env.local is gitignored. None of these are strictly required to run locally,
# but VITE_WC_PROJECT_ID is required for WalletConnect to function properly.

# WalletConnect project ID — sign up free at https://cloud.walletconnect.com/
# Without this, the WalletConnect option in RainbowKit won't work (but injected
# browser wallets like MetaMask, Coinbase Wallet, etc. still do).
VITE_WC_PROJECT_ID=

# Base mainnet RPC (chain 8453). Defaults to the public RPC if unset, which is
# fine for casual local dev but rate-limited under real traffic. For production
# / launch traffic use Alchemy, QuickNode, or a self-hosted node.
VITE_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# Optional: Base Sepolia RPC override. Only needed if you're QA-ing the testnet
# build. Public endpoint is fine for hobby use.
# VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Launch gate. Default behavior (unset, or `false`) renders the splash /
# coming-soon page. Set to "true" to open the full app.
# You can also force open via the URL query: https://mochigarden.xyz/?preview=1
VITE_LAUNCH_OPEN=true
