# Mochi Garden deploy env — copy to .env and fill in.
# .env is gitignored. Never commit a real PRIVATE_KEY.

# Deployer wallet — must be funded with ETH on the chain you're deploying to.
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Optional: where the 1% protocol fee on buys/mints lands.
# Defaults to the deployer if unset.
# DEV_TREASURY=0x_YOUR_TREASURY_HERE

# ---------------------------------------------------------------------------
# Pick the PoolManager + RPC for the chain you're deploying to.
# Comment / uncomment as needed. Leaving POOL_MANAGER unset (or 0x0) makes
# the script deploy a fresh PoolManager (Anvil only — don't do this on a real
# chain that already has v4).
# ---------------------------------------------------------------------------

# Base Sepolia (chain 84532)
POOL_MANAGER=0x05E73354cFDd6745C338b50BcFDfA3Aa6fA03408
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base mainnet (chain 8453) — uncomment the two lines below + comment the two
# above when deploying to mainnet. Verify the PoolManager address against
# https://docs.uniswap.org/contracts/v4/deployments before the first deploy.
# POOL_MANAGER=0x498581fF718922c3f8e6A244956aF099B2652b2b
# BASE_RPC_URL=https://mainnet.base.org

# Etherscan v2 multichain API key — same key works for Base + Base Sepolia.
# Get a free key at https://etherscan.io/myapikey. Required for forge verify-contract.
# ETHERSCAN_API_KEY=YOUR_KEY
